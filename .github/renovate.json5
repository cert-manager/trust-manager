{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>cert-manager/makefile-modules:renovate-config.json5',
  ],
  customManagers: [
    {
      customType: 'jsonata',
      fileFormat: 'yaml',
      managerFilePatterns: [
        '^\\.custom-gcl\\.yml$'
      ],
      matchStrings: [
        'plugins.{"depName": module, "currentValue": version }'
      ],
      datasourceTemplate: 'go',
      versioningTemplate: 'go',
    }
  ]
}
